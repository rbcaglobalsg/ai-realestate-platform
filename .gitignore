# AI 부동산 플랫폼 .gitignore

# ─── Node.js ─────────────────────────────────────
node_modules/

# ─── 환경변수 ────────────────────────────────────
.env
.env.local
.env.*.local

# ─── 로그 파일 ───────────────────────────────────
*.log
npm-debug.log*

# ─── 수집 데이터 (원본) ──────────────────────────
data/raw/

# ─── Python ──────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.venv/
venv/

# ─── OS 파일 ─────────────────────────────────────
.DS_Store
Thumbs.db

# ─── IDE ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── 빌드 산출물 ─────────────────────────────────
frontend/dist/
