# AI 부동산 플랫폼 백엔드 환경 변수

# FAL AI (설계 이미지 생성)
FAL_API_KEY=your_fal_api_key

# OpenAI (수익성 분석 - Phase 3)
OPENAI_API_KEY=your_openai_api_key

# 공공데이터포털 API 키 (전부 무료 — data.go.kr에서 발급)
PUBLIC_DATA_API_KEY=your_data_go_kr_decoding_key

# VWorld API 키 (공간정보 — vworld.kr에서 발급)
VWORLD_API_KEY=your_vworld_key

# 데이터베이스 (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# 서버 포트
PORT=3001

# Toss Payments (상용화 후 — Phase 4)
TOSS_SECRET_KEY=your_toss_secret_key
